{
  "version": 2,
  "buildCommand": "pnpm turbo build",
  "outputDirectory": "frontend/.next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/dist/index.js"
    }
  ]
}
